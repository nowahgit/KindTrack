rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Koleksi 'kindness' — semua user yang login bisa membaca untuk fitur Community Forum, tapi hanya penulisnya yang bisa edit/hapus
    match /kindness/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Koleksi 'users' — hanya user yang bersangkutan yang bisa baca/tulis profilnya
    // Tapi kita perlu allow read untuk fetch nama/avatar oleh author lain
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /likes/{docId} { allow read, write: if request.auth != null; }
    match /comments/{docId} { allow read, write: if request.auth != null; }
    match /reports/{docId} { allow read, write: if request.auth != null; }
    match /follows/{docId} { allow read, write: if request.auth != null; }

    // Semua koleksi lain — tidak ada akses
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
