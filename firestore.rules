rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Kindness posts
    match /kindness/{docId} {
      allow read: if request.auth != null;
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // Community features
    match /likes/{docId} { allow read, write: if request.auth != null; }
    match /comments/{docId} { 
      allow read: if request.auth != null;
      allow delete: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.postAuthorId == request.auth.uid));
      allow create: if request.auth != null;
    }
    match /reports/{docId} { 
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow delete: if isAdmin();
    }
    match /follows/{docId} { allow read, write: if request.auth != null; }

    // User Chats
    match /chats/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      allow update: if request.auth != null && resource.data.senderId == request.auth.uid && resource.data.senderRole != 'admin';
      allow delete: if request.auth != null && resource.data.senderId == request.auth.uid && resource.data.senderRole != 'admin';
    }

    // Admin Chats
    match /admin_chats/{docId} {
      allow read: if isAdmin() || (request.auth != null && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid));
      allow create: if request.auth != null;
    }

    // Global admin bypass
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
